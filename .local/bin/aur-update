#!/usr/bin/env bash

AUR_DIR="$HOME/.cache/aur/clone"

if [ ! -d "$AUR_DIR" ]; then
    echo "A megadott mappa nem létezik: $AUR_DIR"
    exit 1
fi

for dir in "$AUR_DIR"/*/; do
    if [ -d "$dir" ] && [ -d "$dir/.git" ]; then
        pkgname=$(basename "$dir")
        echo -e "\n\033[1;34m==> Ellenőrzés: $pkgname\033[0m"
        cd "$dir" || continue
        
        # 1. AUR infók frissítése (git pull)
        git pull -q
        
        # 2. Megnézzük a jelenleg telepített verziót
        installed_ver=$(pacman -Q "$pkgname" 2>/dev/null | awk '{print $2}')
        
        if [ -z "$installed_ver" ]; then
            echo "   -> A csomag nincs telepítve, fordítás indul..."
            makepkg -si
            continue
        fi

        # 3. Kinyerjük a legfrissebb elérhető verziót (fordítás nélkül!)
        # A -o/--nobuild lefuttatja a pkgver() függvényt a legfrissebb git kód alapján
        makepkg -od --noprepare &>/dev/null
        available_ver=$(makepkg --packagelist 2>/dev/null | head -n1 | awk -F'-' '{print $(NF-2)"-"$(NF-1)}')

        # Ha a makepkg --packagelist nem működne valamiért, fallback a PKGBUILD-ből kinyert adatra
        if [ -z "$available_ver" ]; then
            source ./PKGBUILD
            available_ver="${pkgver}-${pkgrel}"
        fi

        # 4. Verziók összehasonlítása
        if [ "$installed_ver" = "$available_ver" ]; then
            echo -e "   \033[1;32m✓ Naprakész ($installed_ver)\033[0m -> Fordítás átugorva."
        else
            echo -e "   \033[1;33m⚡ Frissítés elérhető!\033[0m ($installed_ver -> $available_ver)"
            echo "   -> Fordítás és telepítés indul..."
            makepkg -si --needed
        fi
    fi
done
